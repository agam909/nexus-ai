# ── LLM (Groq) ──────────────────────────────────────────────
# Free key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Embeddings (HuggingFace Inference API - free) ───────────
# Free token: https://huggingface.co/settings/tokens  (read access is enough)
HF_API_TOKEN=
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── Vector DB (Qdrant Cloud free tier) ──────────────────────
# Free 1 GB cluster: https://cloud.qdrant.io/
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=nexus_docs

# ── Database ────────────────────────────────────────────────
# Free Postgres: https://neon.tech/  (paste the "connection string")
# Local fallback: sqlite+aiosqlite:///./data/nexus.db
DATABASE_URL=sqlite+aiosqlite:///./data/nexus.db

# ── Auth ────────────────────────────────────────────────────
# CHANGE THIS in production. Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=43200

# ── HTTP ────────────────────────────────────────────────────
CORS_ORIGINS=*
HOST=0.0.0.0
PORT=8000

# ── RAG ─────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=4
